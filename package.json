{
	"name": "niimblue",
	"private": true,
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev-check": "npm run sv-check && npm run dev",
		"dev": "vite",
		"dev-local-lib": "vite --force",
		"build": "vite build",
		"build-rel": "vite build --base=./",
		"preview": "vite preview",
		"sv-check": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test-watch": "vitest",
		"gen-mdi-list": "node gen-mdi-list.mjs > src/styles/mdi_icons.ts",
		"lint": "eslint .",
		"format-all": "prettier --write \"src/**/*.{ts,svelte}\" \"!src/styles/mdi_icons.ts\""
	},
	"dependencies": {
		"@capacitor/core": "^8.3.0",
		"@capacitor/filesystem": "^8.1.2",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/local-notifications": "^8.2.0",
		"@capacitor/share": "^8.0.1",
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@formatjs/intl-localematcher": "^0.6.2",
		"@iconify/svelte": "^5.2.1",
		"@mmote/niimbluelib": "0.0.1-alpha.39",
		"@popperjs/core": "^2.11.8",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"bootstrap": "5.3.8",
		"cropperjs": "^2.1.1",
		"d3-dsv": "^3.0.1",
		"dayjs": "^1.11.19",
		"dexie": "^4.4.2",
		"fabric": "^7.1.0",
		"material-icons": "^1.13.14",
		"minisearch": "^7.2.0",
		"pdfjs-dist": "^5.4.624",
		"qrcode-generator": "2.0.4",
		"svelte-bottom-sheet": "^2.3.0",
		"toastify-js": "^1.12.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.0",
		"@iconify-json/material-symbols": "^1.2.73",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.3.0",
		"@tsconfig/svelte": "^5.0.5",
		"@types/bootstrap": "^5.2.10",
		"@types/d3-dsv": "^3.0.7",
		"@types/node": "^24.10.0",
		"@types/qrcode-svg": "^1.1.5",
		"@types/toastify-js": "^1.12.4",
		"emojibase-data": "^17.0.0",
		"eslint-plugin-svelte": "^3.13.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^16.5.0",
		"openmoji": "^17.0.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"sass": "1.77.6",
		"svelte": "^5.43.2",
		"svelte-check": "^4.3.3",
		"tailwindcss": "^4.3.0",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.3",
		"vite": "^7.3.2",
		"vitest": "^3.2.6"
	},
	"overrides": {
		"fabric": {
			"canvas": "npm:uninstall"
		}
	}
}
